# Copy to .env and fill in from the STAGING Supabase project
# (dashboard -> Project Settings -> API). Development and Expo Go always
# point at staging; production values are injected at build time (EAS), never here.
EXPO_PUBLIC_SUPABASE_URL=https://your-staging-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=paste-staging-anon-key

# Observability — leave disabled in development.
EXPO_PUBLIC_SENTRY_ENABLED=false
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_ENABLED=false
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
